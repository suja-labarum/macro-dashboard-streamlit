{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Macro AI Analysis Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "headline",
    "plain_english_summary",
    "analyst_detail_markdown",
    "key_watch_items",
    "missing_data",
    "data_quality_markdown",
    "confidence_label",
    "confidence_reason"
  ],
  "properties": {
    "headline": {
      "type": "string",
      "minLength": 1
    },
    "plain_english_summary": {
      "type": "string",
      "minLength": 1
    },
    "analyst_detail_markdown": {
      "type": "string",
      "minLength": 1
    },
    "key_watch_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "missing_data": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "data_quality_markdown": {
      "type": "string",
      "minLength": 1
    },
    "confidence_label": {
      "type": "string",
      "enum": [
        "Low",
        "Medium",
        "High"
      ]
    },
    "confidence_reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
